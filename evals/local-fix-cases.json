    "id": "sampleformosaic-collections-modal",
    "repoFullName": "liamkernan/sampleformosaic",
    "repoDirName": "sampleformosaic",
    "baseRef": "c0b6918",
    "feedback": {
      "source": "web_form",
      "rawContent": "add pop ups when the user clicks on any of the popular collections, ie kitchen workspace living room, that show more information maybe pictures maybe reviews prices etc",
      "senderIdentifier": "eval@example.com",
      "category": "feature_request",
      "complexity": "moderate",
      "summary": "Add popup modals with detailed information for popular collection cards",
      "relevantFiles": ["index.html", "script.js", "styles.css"],
      "confidence": 0.8
    },
    "expectedReferenceFiles": ["README.md"],
    "requiredChangedFilePatterns": ["index.html", [".js"], [".css"]],
    "requiredFileContains": [
      {
        "path": "index.html",
        "text": "collection"
      },
      {
        "path": [".js"],
        "text": "collection"
      }
    ],
    "frontendAssertions": [
      {
        "name": "Kitchen collection opens a populated modal",
        "click": [
          ".collection-card-clickable[data-collection=\"kitchen\"]",
          ".collection-card[data-collection=\"kitchen\"]",
          "[data-collection=\"kitchen\"]",
          ".collection-trigger[data-modal=\"modal-kitchen\"]",
          "[data-modal=\"modal-kitchen\"]"
        ],
        "expect": [
          {
            "selector": ["#collectionModalOverlay", "#modal-kitchen"],
            "hasClass": ["is-open", "is-visible", "active", "modal-overlay--open"]
          },
          {
            "selector": ["#modalTitle", "#collectionModalTitle", "#modal-kitchen-title"],
            "textIncludes": "Kitchen"
          },
          {
            "selector": [
              "#modalItems .modal-item-card",
              "#collectionModalProducts .collection-modal-product",
              "#collectionModalProducts > *",
              "#modal-kitchen .modal-product-item",
              "#modal-kitchen .modal-product-list > *"
            ],
            "minCount": 2
          },
          {
            "selector": [
              "#modalReviewList .modal-review-item",
              "#collectionModalReviewList .collection-modal-review",
              "#collectionModalReviewList > *",
              "#modal-kitchen .modal-review",
              "#modal-kitchen .modal-reviews > *"
            ],
            "minCount": 1
          }
        ]
      }
    ]
  },
