{
  "name": "mosaic",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm build && concurrently \"docker compose up redis\" \"pnpm webhooks:dev\" \"pnpm --filter @mosaic/github-app dev\" \"pnpm --filter @mosaic/intake dev\" \"pnpm --filter @mosaic/pipeline dev\" \"pnpm --filter @mosaic/discord-bot dev\" \"pnpm --filter @mosaic/slack-bot dev\"",
    "start": "concurrently \"pnpm --filter @mosaic/github-app start\" \"pnpm --filter @mosaic/intake start\" \"pnpm --filter @mosaic/pipeline start\" \"pnpm --filter @mosaic/discord-bot start\" \"pnpm --filter @mosaic/slack-bot start\"",
    "build": "pnpm -r build",
    "verify:image": "docker build -f Dockerfile.verify -t mosaic-verify:local .",
    "lint": "eslint .",
    "typecheck": "tsc -b packages/*/tsconfig.json",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:security:docker": "MOSAIC_REQUIRE_DOCKER_TESTS=1 vitest run tests/pipeline-verification-runner.test.ts",
    "test:watch": "vitest",
    "eval:local": "tsx scripts/eval-local-fixes.ts",
    "eval:routing": "tsx scripts/eval-routing-benchmark.ts",
    "setup": "tsx scripts/setup.ts",
    "demo": "tsx scripts/demo.ts",
    "webhooks:dev": "node scripts/dev-webhooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitest/coverage-v8": "3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "ulid": "^2.4.0",
    "vitest": "^3.1.1",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  }
}
