{
  "name": "feedbackbot",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm build && concurrently \"docker compose up redis\" \"pnpm --filter @feedbackbot/github-app dev\" \"pnpm --filter @feedbackbot/intake dev\" \"pnpm --filter @feedbackbot/pipeline dev\"",
    "start": "concurrently \"pnpm --filter @feedbackbot/github-app start\" \"pnpm --filter @feedbackbot/intake start\" \"pnpm --filter @feedbackbot/pipeline start\"",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "tsc -b packages/*/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "tsx scripts/setup.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "ulid": "^2.4.0",
    "vitest": "^3.1.1",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  }
}
