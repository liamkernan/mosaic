# GitHub App (required)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# Redis (required)
REDIS_URL=redis://localhost:6379

# LLM — Platform key (optional, only if offering hosted mode)
ANTHROPIC_API_KEY=

# Email intake (optional)
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_POLL_INTERVAL_MS=30000

# Discord (optional)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Server
PORT=3000
GITHUB_APP_PORT=3001
LOG_LEVEL=info
REPO_CACHE_DIR=~/.feedbackbot/repos
WORKER_CONCURRENCY=3
LLM_CALLS_PER_HOUR=50
PRS_PER_HOUR=10
FEEDBACK_ITEMS_PER_HOUR=100
FEEDBACKBOT_TRIGGER_PHRASE=@feedbackbot
