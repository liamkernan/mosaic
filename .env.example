# GitHub App (required)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=
SMEE_URL=

# Redis (required)
REDIS_URL=redis://localhost:6379

# LLM — Anthropic remains the default. Set MOSAIC_LLM_PROVIDER=openai to switch.
MOSAIC_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Email intake (optional)
# Local single-repo mailbox. This mailbox routes every unread message to EMAIL_REPO_FULL_NAME.
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_REPO_FULL_NAME=
EMAIL_POLL_INTERVAL_MS=30000

# Production multi-repo mailbox list. Prefer deployment secrets over committing this value.
# Each mailbox is dedicated to exactly one repo.
# EMAIL_MAILBOXES=[{"repoFullName":"owner/project-a","host":"imap.example.com","port":993,"user":"project-a-support@example.com","pass":"app-password"},{"repoFullName":"owner/project-b","host":"imap.example.com","port":993,"user":"project-b-support@example.com","pass":"app-password"}]

# Discord (optional)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
# Local fallback route when no production mapping matches.
DISCORD_DEFAULT_REPO=
# Production routing. Prefer deployment secrets over committing this value.
# DISCORD_REPO_MAPPINGS=[{"guildId":"1234567890","channelId":"2345678901","repoFullName":"owner/project-a"},{"guildId":"1234567890","repoFullName":"owner/default-repo"}]
DISCORD_INTAKE_URL=http://127.0.0.1:3000/webhook/discord
DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=false

# Slack
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
# Local fallback route when no production mapping matches.
SLACK_DEFAULT_REPO=
# Production routing. Prefer deployment secrets over committing this value.
# SLACK_REPO_MAPPINGS=[{"teamId":"T1234567890","channelId":"C2345678901","repoFullName":"owner/project-a"},{"teamId":"T1234567890","repoFullName":"owner/default-repo"}]
SLACK_INTAKE_URL=http://127.0.0.1:3000/webhook/slack

# Server
PORT=3000
GITHUB_APP_PORT=3001
LOG_LEVEL=info
REPO_CACHE_DIR=~/.mosaic/repos
WORKER_CONCURRENCY=3
WORKER_LOCK_DURATION_MS=600000
WORKER_STALLED_INTERVAL_MS=120000
WORKER_MAX_STALLED_COUNT=3
LLM_CALLS_PER_HOUR=50
PRS_PER_HOUR=10
FEEDBACK_ITEMS_PER_HOUR=100
MOSAIC_INTAKE_SHARED_SECRET=
# Optional dedicated signing secret for hidden staged issue metadata.
# Defaults to MOSAIC_INTAKE_SHARED_SECRET, then GITHUB_WEBHOOK_SECRET.
MOSAIC_STAGED_ISSUE_SECRET=
MOSAIC_TRIGGER_PHRASE=@mosaic

# Embeddable web feedback forms (optional)
# Add one entry per customer/site. The public embedKey is safe to place in a script tag;
# repoFullName and allowedOrigins are enforced server-side.
# MOSAIC_FORM_EMBEDS=[{"embedKey":"project-a-site","repoFullName":"owner/project-a","allowedOrigins":["https://www.example.com"],"displayName":"Send feedback","requireEmail":false,"minSubmitMs":1200}]
