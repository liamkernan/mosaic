FROM node:22.15.0-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/mosaic-verify

RUN npm init -y \
  && npm install --omit=dev --no-audit --no-fund jsdom@29.1.1 \
  && npm cache clean --force

CMD ["node", "--version"]
