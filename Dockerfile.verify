FROM node:22.15.0-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    python3=3.11.2-1+b1 \
    python3-pip=23.0.1+dfsg-1 \
    python3-pytest=7.2.1-2 \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/mosaic-verify

RUN npm init -y \
  && npm install --omit=dev --no-audit --no-fund jsdom@29.1.1 \
  && npm cache clean --force

CMD ["node", "--version"]
